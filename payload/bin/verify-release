#!/usr/bin/env bash
# Verify a downloaded Ubuntu Zombie release directory.
set -Eeuo pipefail

REPO="${ZOMBIE_RELEASE_REPO:-japer-technology/ubuntu-zombie}"
CERT_IDENTITY_REGEXP="${ZOMBIE_RELEASE_CERT_IDENTITY_REGEXP:-https://github.com/${REPO}/.+}"
CERT_OIDC_ISSUER="${ZOMBIE_RELEASE_CERT_OIDC_ISSUER:-https://token.actions.githubusercontent.com}"

usage() {
  cat <<EOF
Usage: verify-release [release-directory]

Verifies a downloaded Ubuntu Zombie release directory by checking SHA256SUMS,
cosign signatures, and the local SLSA provenance attestation bundle.

Environment:
  ZOMBIE_RELEASE_REPO                    GitHub repository (${REPO})
  ZOMBIE_RELEASE_CERT_IDENTITY_REGEXP    Expected signing identity regexp
  ZOMBIE_RELEASE_CERT_OIDC_ISSUER        Expected OIDC issuer
EOF
}

need() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "[x] missing required command: $1" >&2
    exit 127
  }
}

status() {
  printf '[%s] %s\n' "$1" "$2"
}

release_dir="${1:-.}"
case "${release_dir}" in
  -h|--help) usage; exit 0 ;;
esac

need sha256sum
need cosign
need gh

cd "${release_dir}"

[[ -s SHA256SUMS ]] || { echo "[x] SHA256SUMS missing or empty" >&2; exit 1; }

mapfile -t artifacts < <(awk '{print $2}' SHA256SUMS | sed 's/^\*//' | grep -v '^$')
if [[ "${#artifacts[@]}" -eq 0 ]]; then
  echo "[x] SHA256SUMS does not list any artifacts" >&2
  exit 1
fi

status i "checking SHA256SUMS"
sha256sum -c SHA256SUMS
status ok "checksums match"

verify_cosign() {
  local file="$1"
  local args=(
    verify-blob
    --certificate-identity-regexp "${CERT_IDENTITY_REGEXP}"
    --certificate-oidc-issuer "${CERT_OIDC_ISSUER}"
  )

  if [[ -s "${file}.cosign.bundle" ]]; then
    args+=(--bundle "${file}.cosign.bundle")
  elif [[ -s "${file}.sig" && -s "${file}.pem" ]]; then
    args+=(--signature "${file}.sig" --certificate "${file}.pem")
  else
    echo "[x] missing cosign signature material for ${file}" >&2
    exit 1
  fi

  cosign "${args[@]}" "${file}" >/dev/null
}

status i "checking cosign signatures"
for artifact in "${artifacts[@]}" SHA256SUMS; do
  [[ -s "${artifact}" ]] || { echo "[x] missing artifact: ${artifact}" >&2; exit 1; }
  verify_cosign "${artifact}"
done
status ok "cosign signatures verify"

provenance_file="$(find . -maxdepth 1 -type f -name '*.intoto.jsonl' -print -quit)"
[[ -n "${provenance_file}" ]] || {
  echo "[x] SLSA provenance attestation (*.intoto.jsonl) missing" >&2
  exit 1
}

status i "checking SLSA provenance"
for artifact in "${artifacts[@]}"; do
  gh attestation verify "${artifact}" \
    --repo "${REPO}" \
    --bundle "${provenance_file}" >/dev/null
done
status ok "provenance verifies"
status ok "release verified"
