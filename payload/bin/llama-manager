#!/usr/bin/env python3
"""Manage the standalone, PC-wide llama.cpp service."""

from __future__ import annotations

import argparse
import json
import os
import platform
import subprocess
import sys
import urllib.error
import urllib.request
from pathlib import Path
from typing import Any


CONFIG_PATH = Path("/etc/llama.cpp/config.json")
UNIT = "llama-server.service"


def load_config() -> dict[str, Any]:
    """Load the installer-owned standalone llama configuration."""
    try:
        data = json.loads(CONFIG_PATH.read_text(encoding="utf-8"))
    except (OSError, ValueError) as exc:
        raise RuntimeError(f"cannot read {CONFIG_PATH}: {exc}") from exc
    if not isinstance(data, dict) or data.get("schema_version") != 1:
        raise RuntimeError(f"{CONFIG_PATH} has an unsupported schema")
    return data


def systemctl(*args: str, check: bool = True) -> subprocess.CompletedProcess[str]:
    """Run systemctl for the fixed llama unit."""
    return subprocess.run(
        ["systemctl", *args, UNIT],
        check=check,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def service_property(name: str) -> str:
    """Read one systemd property without failing when systemd is unavailable."""
    result = systemctl("show", f"--property={name}", "--value", check=False)
    return result.stdout.strip() if result.returncode == 0 else "unknown"


def api_request(path: str, method: str = "GET", body: bytes | None = None) -> Any:
    """Call the fixed loopback API."""
    config = load_config()
    url = f"http://127.0.0.1:{int(config['port'])}{path}"
    request = urllib.request.Request(
        url,
        data=body,
        method=method,
        headers={"Accept": "application/json", "Content-Type": "application/json"},
    )
    with urllib.request.urlopen(request, timeout=10) as response:
        return json.loads(response.read(1024 * 1024))


def status_payload() -> dict[str, Any]:
    """Return stable machine-readable service status."""
    config = load_config()
    active = service_property("ActiveState")
    enabled = systemctl("is-enabled", check=False).stdout.strip() or "unknown"
    healthy = False
    if active == "active":
        try:
            api_request("/health")
            healthy = True
        except (OSError, ValueError, urllib.error.URLError):
            healthy = False
    state = "ready" if healthy else (
        "installed-stopped" if active == "inactive" else active
    )
    return {
        "state": state,
        "active": active,
        "enabled": enabled,
        "healthy": healthy,
        "url": f"http://127.0.0.1:{int(config['port'])}/v1",
        "model": config["model_id"],
        "runtime": config["runtime_release"],
    }


def print_status(as_json: bool) -> int:
    """Print service status."""
    payload = status_payload()
    if as_json:
        print(json.dumps(payload, sort_keys=True))
    else:
        print(f"State:   {payload['state']}")
        print(f"API:     {payload['url']}")
        print(f"Model:   {payload['model']}")
        print(f"Runtime: {payload['runtime']}")
        print(f"Boot:    {payload['enabled']}")
    return 0 if payload["healthy"] else 1


def mutate(command: str) -> int:
    """Apply a fixed systemd lifecycle operation."""
    if os.geteuid() != 0:
        print(f"llama-manager {command} requires root", file=sys.stderr)
        return 1
    result = systemctl(command, check=False)
    if result.returncode != 0:
        print(result.stderr.strip(), file=sys.stderr)
    return result.returncode


def print_models(as_json: bool) -> int:
    """List models advertised by the server."""
    try:
        payload = api_request("/v1/models")
    except (OSError, ValueError, urllib.error.URLError) as exc:
        print(f"llama API unavailable: {exc}", file=sys.stderr)
        return 1
    rows = payload.get("data", []) if isinstance(payload, dict) else []
    models = [
        row["id"] for row in rows
        if isinstance(row, dict) and isinstance(row.get("id"), str)
    ]
    print(json.dumps(models) if as_json else "\n".join(models))
    return 0


def test_api() -> int:
    """Run a bounded OpenAI-compatible inference probe."""
    config = load_config()
    body = json.dumps({
        "model": config["model_id"],
        "messages": [{"role": "user", "content": "Reply with OK."}],
        "max_tokens": 8,
        "temperature": 0,
    }).encode()
    try:
        payload = api_request("/v1/chat/completions", "POST", body)
    except (OSError, ValueError, urllib.error.URLError) as exc:
        print(f"llama API test failed: {exc}", file=sys.stderr)
        return 1
    choices = payload.get("choices") if isinstance(payload, dict) else None
    if not isinstance(choices, list) or not choices:
        print("llama API returned no completion", file=sys.stderr)
        return 1
    print("llama API test passed")
    return 0


def print_hardware(as_json: bool) -> int:
    """Print non-sensitive CPU and memory capacity."""
    memory_kib = 0
    try:
        for line in Path("/proc/meminfo").read_text(encoding="utf-8").splitlines():
            if line.startswith("MemTotal:"):
                memory_kib = int(line.split()[1])
                break
    except (OSError, ValueError, IndexError):
        pass
    payload = {
        "architecture": platform.machine(),
        "logical_cpus": os.cpu_count(),
        "memory_bytes": memory_kib * 1024,
        "compute": "cpu",
    }
    if as_json:
        print(json.dumps(payload, sort_keys=True))
    else:
        print(f"Architecture: {payload['architecture']}")
        print(f"Logical CPUs: {payload['logical_cpus']}")
        print(f"Memory:       {payload['memory_bytes']} bytes")
        print("Compute:      cpu")
    return 0


def serve() -> None:
    """Replace this process with the pinned managed llama-server."""
    config = load_config()
    executable = Path(str(config["runtime_dir"])) / "llama-server"
    model = Path(str(config["model_path"]))
    if not executable.is_file() or not model.is_file():
        raise RuntimeError("managed runtime or model is missing")
    args = [
        str(executable),
        "--host", "127.0.0.1",
        "--port", str(int(config["port"])),
        "--model", str(model),
        "--ctx-size", str(int(config["context_size"])),
        "--threads", str(int(config["threads"])),
        "--alias", str(config["model_id"]),
    ]
    runtime_dir = str(config["runtime_dir"])
    current_library_path = os.environ.get("LD_LIBRARY_PATH", "")
    os.environ["LD_LIBRARY_PATH"] = (
        f"{runtime_dir}:{current_library_path}"
        if current_library_path else runtime_dir
    )
    os.execv(executable, args)


def main() -> int:
    """CLI entry point."""
    parser = argparse.ArgumentParser(prog="llama-manager")
    parser.add_argument("--json", action="store_true")
    subparsers = parser.add_subparsers(dest="command", required=True)
    for command in ("status", "start", "stop", "restart", "enable", "disable",
                    "test", "models", "hardware"):
        subparsers.add_parser(command)
    subparsers.add_parser("serve", help=argparse.SUPPRESS)
    args = parser.parse_args()
    if args.command == "status":
        return print_status(args.json)
    if args.command in {"start", "stop", "restart", "enable", "disable"}:
        return mutate(args.command)
    if args.command == "test":
        return test_api()
    if args.command == "models":
        return print_models(args.json)
    if args.command == "hardware":
        return print_hardware(args.json)
    if args.command == "serve":
        serve()
        return 0
    return 2


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except RuntimeError as exc:
        print(f"llama-manager: {exc}", file=sys.stderr)
        raise SystemExit(1) from exc
