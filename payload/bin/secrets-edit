#!/usr/bin/env bash
# secrets-edit — safely edit /opt/ai-zombie/secrets/env.
# Re-asserts ownership and 0600 after the editor exits, even on error.
set -euo pipefail

SECRETS_FILE="${ZOMBIE_DIR:-/opt/ai-zombie}/secrets/env"
AGENT_USER="${AGENT_USER:-agent}"

usage() {
  cat <<EOF
secrets-edit — safely edit ${SECRETS_FILE}.

Usage:
  sudo secrets-edit [-h|--help]

Opens the secrets file in \$SUDO_EDITOR/\$EDITOR/\$VISUAL (default nano),
creating it with a commented template on first run. A timestamped
backup is written before editing (last 10 kept), and ownership plus
mode 600 are re-asserted after the editor exits — even on error.

Environment:
  ZOMBIE_DIR    Install root (default /opt/ai-zombie).
  AGENT_USER    Owner of the secrets file (default agent).

Restart the chat service afterwards to pick up changes:
  sudo systemctl restart ubuntu-zombie-chat.service
EOF
}

case "${1:-}" in
  -h|--help) usage; exit 0 ;;
  "") ;;
  *) echo "secrets-edit: unknown argument: $1" >&2; usage >&2; exit 2 ;;
esac

if [[ "${EUID}" -ne 0 ]]; then
  echo "secrets-edit must be run as root (try: sudo $0)" >&2
  exit 1
fi

if [[ ! -e "${SECRETS_FILE}" ]]; then
  install -d -m 700 -o "${AGENT_USER}" -g "${AGENT_USER}" \
    "$(dirname "${SECRETS_FILE}")"
  install -m 600 -o "${AGENT_USER}" -g "${AGENT_USER}" \
    /dev/null "${SECRETS_FILE}"
  cat > "${SECRETS_FILE}" <<EOF
# Ubuntu Zombie secrets. Mode 600, owned by ${AGENT_USER}.
# Pick ONE provider and paste its key. All providers are routed
# through @earendil-works/pi-ai; see docs/CONFIGURATION.md.
#
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# XAI_API_KEY=...
# OPENROUTER_API_KEY=...
# MISTRAL_API_KEY=...
# GROQ_API_KEY=...
#
# Optional:
# ZOMBIE_PROVIDER=openai          # openai|anthropic|gemini|xai|openrouter|mistral|groq
# ZOMBIE_MODEL=gpt-4o-mini        # override default model (required for openrouter)
# ZOMBIE_CHAT_PORT=7878
EOF
fi

restore_perms() {
  chown "${AGENT_USER}:${AGENT_USER}" "${SECRETS_FILE}"
  chmod 600 "${SECRETS_FILE}"
}
trap restore_perms EXIT

# Back up the existing secrets file before invoking the editor so a
# fat-finger save can be recovered without re-typing the API key.
# Backups are mode 600, owned by AGENT_USER, kept under
# secrets/backups/ alongside the live env file. Only the most recent
# 10 backups are retained; older ones are pruned on every edit.
BACKUP_DIR="$(dirname "${SECRETS_FILE}")/backups"
install -d -m 700 -o "${AGENT_USER}" -g "${AGENT_USER}" "${BACKUP_DIR}"
if [[ -s "${SECRETS_FILE}" ]]; then
  BACKUP_TS="$(date -u +%Y%m%dT%H%M%SZ)"
  BACKUP_FILE="${BACKUP_DIR}/env.${BACKUP_TS}"
  install -m 600 -o "${AGENT_USER}" -g "${AGENT_USER}" \
    "${SECRETS_FILE}" "${BACKUP_FILE}"
  echo "[i] Backup written: ${BACKUP_FILE}"
  # Keep the last 10 backups (newest first), prune the rest.
  # shellcheck disable=SC2012 # ls -t output is intentional, names are time-stamped.
  ls -1t "${BACKUP_DIR}"/env.* 2>/dev/null \
    | tail -n +11 \
    | xargs -r rm -f --
fi

EDITOR_CMD="${SUDO_EDITOR:-${EDITOR:-${VISUAL:-nano}}}"
"${EDITOR_CMD}" "${SECRETS_FILE}"

# If the file was emptied or truncated by mistake, point the operator
# at the most recent backup so they can restore it.
if [[ ! -s "${SECRETS_FILE}" ]] && compgen -G "${BACKUP_DIR}/env.*" >/dev/null; then
  # shellcheck disable=SC2012
  LATEST="$(ls -1t "${BACKUP_DIR}"/env.* | head -n 1)"
  echo
  echo "[!] WARNING: ${SECRETS_FILE} is now empty." >&2
  echo "[!] To roll back to the previous version, run:" >&2
  echo "      sudo cp -a ${LATEST} ${SECRETS_FILE}" >&2
  echo "      sudo chown ${AGENT_USER}:${AGENT_USER} ${SECRETS_FILE}" >&2
  echo "      sudo chmod 600 ${SECRETS_FILE}" >&2
fi

echo
echo "Saved. Restart the chat service to pick up the new value:"
echo "  sudo systemctl restart ubuntu-zombie-chat.service"
