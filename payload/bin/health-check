#!/usr/bin/env bash
# health-check — one-shot health summary for Ubuntu Zombie.
set -uo pipefail

usage() {
  cat <<EOF
health-check — one-shot health summary for Ubuntu Zombie.

Usage:
  health-check [-h|--help]

Checks the chat service, chat port, provider credential presence, secrets
permissions, disk space, and audit log, then prints an ok/warn/fail
summary. Exits 1 if any check fails (unless ZOMBIE_HEALTH_WARN_ONLY=1).

Environment:
  ZOMBIE_DIR                Install root (default /opt/ai-zombie).
  ZOMBIE_CHAT_PORT          Chat port to probe (default 7878).
  ZOMBIE_HEALTH_WARN_ONLY   Set to 1 to always exit 0.
EOF
}

case "${1:-}" in
  -h|--help) usage; exit 0 ;;
  "") ;;
  *) echo "health-check: unknown argument: $1" >&2; usage >&2; exit 2 ;;
esac

ZOMBIE_DIR="${ZOMBIE_DIR:-/opt/ai-zombie}"
SECRETS_FILE="${ZOMBIE_DIR}/secrets/env"
ZOMBIE_HEALTH_WARN_ONLY="${ZOMBIE_HEALTH_WARN_ONLY:-0}"

if [[ -t 1 ]]; then
  C_RESET=$'\033[0m'; C_RED=$'\033[31m'; C_GREEN=$'\033[32m'
  C_YEL=$'\033[33m'; C_BOLD=$'\033[1m'
else
  C_RESET=""; C_RED=""; C_GREEN=""; C_YEL=""; C_BOLD=""
fi

PASS=0; FAIL=0; WARN=0
check_ok()   { printf '  %s[ok]%s %s\n' "${C_GREEN}" "${C_RESET}" "$*"; PASS=$((PASS+1)); }
check_warn() { printf '  %s[!]%s  %s\n' "${C_YEL}"   "${C_RESET}" "$*"; WARN=$((WARN+1)); }
check_fail() { printf '  %s[x]%s  %s\n' "${C_RED}"   "${C_RESET}" "$*"; FAIL=$((FAIL+1)); }

printf '%s== ubuntu-zombie health ==%s\n\n' "${C_BOLD}" "${C_RESET}"

# Chat service
if systemctl is-active --quiet ubuntu-zombie-chat.service 2>/dev/null; then
  check_ok "chat service active"
else
  check_fail "chat service not active (sudo systemctl start ubuntu-zombie-chat)"
fi

# Local network visibility
if ss -ltn 2>/dev/null | grep -q ":${ZOMBIE_CHAT_PORT:-7878} "; then
  check_ok "chat port listening"
else
  check_warn "chat port not observed in ss output"
fi

# Provider credential presence (without reading the value)
if [[ -r "${SECRETS_FILE}" ]]; then
  if grep -Eq '^[[:space:]]*(export[[:space:]]+)?(OPENAI|ANTHROPIC|GEMINI|XAI|OPENROUTER|MISTRAL|GROQ|LMSTUDIO)_API_KEY[[:space:]]*=[[:space:]]*.+' "${SECRETS_FILE}" 2>/dev/null; then
    check_ok "provider credential present in secrets/env"
  else
    check_warn "no provider credential in secrets/env (sudo ${ZOMBIE_DIR}/bin/secrets-edit)"
  fi
  PERMS="$(stat -c %a "${SECRETS_FILE}" 2>/dev/null || echo 000)"
  if [[ "${PERMS}" == "600" ]]; then
    check_ok "secrets/env permissions 600"
  else
    check_fail "secrets/env permissions ${PERMS} (must be 600)"
  fi
else
  check_warn "cannot read ${SECRETS_FILE} (this is expected for non-agent users)"
fi

# Disk space
AVAIL_KB="$(df -P / | awk 'NR==2 {print $4}')"
if [[ "${AVAIL_KB:-0}" -gt 2000000 ]]; then
  check_ok "free disk space $((AVAIL_KB/1024)) MB"
elif [[ "${AVAIL_KB:-0}" -gt 500000 ]]; then
  check_warn "low free disk space $((AVAIL_KB/1024)) MB"
else
  check_fail "very low free disk space $((AVAIL_KB/1024)) MB"
fi

# Audit log
AUDIT_LOG="/var/log/ubuntu-zombie/audit.log"
if [[ -f "${AUDIT_LOG}" ]]; then
  check_ok "audit log present ($(wc -l < "${AUDIT_LOG}") entries)"
else
  check_warn "audit log missing (will appear on first chat use)"
fi

echo
printf '%sResult:%s %d ok, %d warn, %d fail\n' "${C_BOLD}" "${C_RESET}" "${PASS}" "${WARN}" "${FAIL}"
if [[ "${FAIL}" -gt 0 && "${ZOMBIE_HEALTH_WARN_ONLY}" != "1" ]]; then exit 1; fi
